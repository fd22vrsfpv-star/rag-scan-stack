# Docker Compose Profiles — controls which optional services start.
# "local-db" = local Postgres. Remove if using external/remote DB.
# Add "gpu" for Ollama, "vault" for Vault, "optional" for OpenWebUI/Kong.
COMPOSE_PROFILES=local-db

API_KEY=changeme
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=scans
POSTGRES_HOST=rag-postgres
POSTGRES_PORT=5432
DB_DSN=postgresql://app:app@rag-postgres:5432/scans

# Database Role Passwords (multi-database setup)
# N8N_PASSWORD=changeme
# EXPLOITDB_PASSWORD=changeme
# SCANS_PASSWORD=changeme
EDB_RW_PASSWORD=changeme

# ZAP
ZAP_API_KEY=changeme
ZAP_ADDR=zap
ZAP_PORT=8090

# Chisel Tunnel
CHISEL_USER=pentest
CHISEL_PASSWORD=changeme

# Metasploit RPC
MSF_RPC_USER=msf
MSF_RPC_PASS=msf
MSF_RPC_HOST=metasploit
MSF_RPC_PORT=55553
MSF_LHOST=
MSF_LPORT=4444

# API / Nmap
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
NMAP_PORT_BATCH=100
NMAP_OUT_DIR=/app/nmap_out
NMAP_SERVICE_DETECTION=1
NMAP_VERSION_INTENSITY=9
# Basic scripts (default):
NMAP_SCRIPTS=banner,http-title,ssl-cert,ssl-enum-ciphers,ssh2-enum-algos
# Extended scripts (uncomment for service enumeration):
# NMAP_SCRIPTS=banner,http-title,http-methods,http-server-header,ssl-cert,ssl-enum-ciphers,ssh2-enum-algos,smtp-commands,smtp-enum-users,smtp-open-relay,smb-enum-shares,smb-os-discovery,ftp-anon,snmp-sysdescr,ldap-search

# Web scanner
WORDLIST=/opt/seclists/Discovery/Web-Content/DirBuster-2007_directory-list-2.3-medium.txt
WEB_PORTS=80,443,8080,8443,8000,8888,3000,5000
DEEP_SCAN_PORTS=1001-65535
SCHEME_HINT=auto

# Nuclei
NUCLEI_SEVERITY=medium,high,critical
NUCLEI_CONCURRENCY=50
NUCLEI_RATELIMIT=150
NUCLEI_TIMEOUT=10
NUCLEI_RETRIES=1
NUCLEI_AUTO_UPDATE=1

# Playwright Scanner
BROWSER_TYPE=chromium
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
USER_AGENT=Mozilla/5.0 (Playwright Security Scanner)
USE_ZAP=true
HEADLESS=true
SCREENSHOT_FORMAT=png

# LLM Backend: "ollama" (default), "vllm", "azure", "openai", or "anthropic"
LLM_BACKEND=ollama

# Ollama LLM
# Windows WSL2: use --profile gpu to start Docker ollama with NVIDIA GPU
# macOS: copy .env.mac.example — uses native Ollama via host.docker.internal
# OLLAMA_URL=http://ollama:11434          # Windows (default, Docker container)
# OLLAMA_URL=http://host.docker.internal:11434  # macOS (native Ollama)
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_TIMEOUT=300

# vLLM (when LLM_BACKEND=vllm)
# VLLM_URL=http://vllm:8000
# VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# VLLM_API_KEY=changeme

# Azure AI Foundry / Azure OpenAI (when LLM_BACKEND=azure)
# AZURE_API_KEY=your-api-key
# AZURE_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_MODEL=gpt-4o
# AZURE_API_VERSION=2024-08-01-preview
# AZURE_EMBED_MODEL=text-embedding-3-small

# OpenAI (when LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_API_BASE=https://api.openai.com

# Anthropic (when LLM_BACKEND=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Autogen Multi-Agent System
# Uses OLLAMA_MODEL, API_KEY, and DB_DSN from above
# Agent coordination for automated penetration testing
AUTO_EXECUTE_SAFE=1

# OSINT / External API Keys
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
PDCP_API_KEY=

# SSH Tunnel (outbound autossh to remote VPS/jumpbox)
# Start: docker compose --profile ssh-tunnel up -d ssh-tunnel
# SSH_REMOTE_HOST=your-vps-ip
# SSH_REMOTE_USER=root
# SSH_REMOTE_PORT=22
# SSH_MODE=dynamic
# SSH_SOCKS_PORT=1080
# SSH_REVERSE_BIND=0.0.0.0:9999
# SSH_REVERSE_TARGET=pentest-dashboard:80
# SSH_LOCAL_PORT=3389
# SSH_LOCAL_TARGET=127.0.0.1:3389
# SSH_KEY_PATH=./ssh-keys
# SSH_KEY_NAME=id_rsa
# SSH_EXTRA_OPTS=

# Open WebUI (optional)
# OLLAMA_BASE_URL=http://ollama:11434
# OPENAI_API_BASE_URL=
# OPENAI_API_KEY=

# W&B for GRPO training (optional)
# WANDB_API_KEY=

# Remote DB via WireGuard (used with docker-compose.remote-db.yml)
# See Docs/REMOTE-DB-SETUP.md for full guide
# WG_SERVER_IP=10.13.13.1
# WG_SERVER_PUBLIC_IP=
# REMOTE_DB_PORT=5432
# REMOTE_DB_USER=app
# REMOTE_DB_PASSWORD=

# Timezone - all containers use Eastern Time
TZ=America/New_York

# ──────────────────────────────────────────────────────────
# HashiCorp Vault (optional — `--profile vault`)
# Set VAULT_ADDR after running:
#   docker compose --profile vault up -d
#   ./scripts/vault-seed.sh
# ──────────────────────────────────────────────────────────
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_MOUNT=secret
VAULT_SKIP_VERIFY=true
VAULT_PORT=8200

# ──────────────────────────────────────────────────────────
# Rate limiting on rag-api (empty disables)
# ──────────────────────────────────────────────────────────
RATE_LIMIT=120/minute

# ──────────────────────────────────────────────────────────
# Scan timeouts (seconds). Per-job payload + admin app_settings beat these.
# ──────────────────────────────────────────────────────────
NMAP_TIMEOUT_FALLBACK=1800
NMAP_TIMEOUT_PROXIED=3600
NMAP_TIMEOUT_SERVICE=600
NMAP_TIMEOUT_UDP=1800
NMAP_TIMEOUT_SMB=300
NMAP_TIMEOUT_RESUME=7200
INGEST_TIMEOUT=600
INGEST_TIMEOUT_SHORT=300
SCAN_TIMEOUT_CACHE_TTL=60
STALE_JOB_TIMEOUT_HOURS=24
MAX_CONCURRENT_SCANS=5
MAX_PIPELINE_CONCURRENT=20
PIPELINE_POLL_INTERVAL=5
RECON_AGENT_BASE_INTERVAL=30

# ──────────────────────────────────────────────────────────
# Container resource limits (per-service overrides commented)
# ──────────────────────────────────────────────────────────
DEFAULT_MEM_LIMIT=4g
DEFAULT_CPUS=2.0
# RAG_API_MEM_LIMIT=6g
# RAG_API_CPUS=4.0
# AUTOGEN_MEM_LIMIT=6g
# AUTOGEN_CPUS=3.0
# EMBEDDER_MEM_LIMIT=8g
# EMBEDDER_CPUS=4.0
# VAULT_MEM_LIMIT=512m

# ──────────────────────────────────────────────────────────
# DB connection pool (rag-api)
# ──────────────────────────────────────────────────────────
DB_POOL_MIN=2
DB_POOL_MAX=40

# ──────────────────────────────────────────────────────────
# BFF outbound HTTP timeout tiers (seconds)
# ──────────────────────────────────────────────────────────
TIMEOUT_FAST=3
TIMEOUT_NORMAL=15
TIMEOUT_LONG=60
TIMEOUT_SCAN=300
TIMEOUT_LLM=600

# ──────────────────────────────────────────────────────────
# LLM tuning (anti-hallucination defaults; override via Settings → LLM Tuning)
# These are compile-time defaults; per-session values stored in app_settings
# take precedence (loaded with 60s cache).
# ──────────────────────────────────────────────────────────
# LLM_TEMPERATURE=0.3
# LLM_TOP_P=0.85
# LLM_TOP_K=40
# LLM_REPEAT_PENALTY=1.1
# LLM_NUM_CTX=8192
# LLM_NUM_PREDICT=4096
# LLM_SEED=0
