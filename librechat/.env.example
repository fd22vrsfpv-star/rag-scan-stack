# LibreChat Environment Variables
# Copy this to .env and customize as needed

# MongoDB
MONGO_URI=mongodb://mongodb:27017/LibreChat

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_KEY=ollama
OLLAMA_MODELS=llama3.1:8b,qwen2.5:14b,qwen2.5:32b

# App Settings
HOST=0.0.0.0
APP_TITLE=LibreChat Pentest Assistant

# Security - CHANGE THESE IN PRODUCTION!
# Generate random secrets using: openssl rand -hex 32
JWT_SECRET=f8d5e9c2a1b7e3f4a8d9c6b2e5f1a7c3d8e4b9f2a6c1e7d3b8f4a9e2c5d1b6f3
JWT_REFRESH_SECRET=a3c7e1f9b2d6a8c4e7f1b9d3a6c8e2f4b7d1a9c5e8f2b6d3a7c1e9f4b8d2a5c6
CREDS_KEY=b4f8d2a6e1c9f7b3d5a8c2e6f1b9d4a7
CREDS_IV=c3e7f1b5d9a2e6c4

# Session Configuration
SESSION_EXPIRY=900000
REFRESH_TOKEN_EXPIRY=604800000

# Authentication
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# Domain Configuration (important for cookies)
DOMAIN_CLIENT=http://localhost:3001
DOMAIN_SERVER=http://localhost:3001

# Features
ENDPOINTS=ollama
DEBUG_CONSOLE=false
