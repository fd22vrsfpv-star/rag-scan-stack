# DB migration backups
backups/

# Swagger/OpenAPI imports (user-provided specs)
import/swagger/

# Presentation materials (conference-specific, not for distribution)
Docs/presentation/
Docs/eval-deck/
Docs/screenshots/

# Images anywhere under Docs/ — keep generated artifacts and dashboard
# screenshots out of the repo. Diagrams that need to ship live in /assets/
# or are referenced by absolute external URL.
Docs/**/*.png
Docs/**/*.jpg
Docs/**/*.jpeg
Docs/**/*.gif

# Any directory literally named screenshots/ — catches future captures from
# capture-screenshots.py / build-deck.py wherever they land.
**/screenshots/

# Root node_modules (from ad-hoc scripts)
node_modules/
package-lock.json

# PEM keys
*.pem

# Vault data + init secrets (NEVER commit)
vault/data/
vault/logs/
vault/init/init.json

# ── Pre-public hardening ──────────────────────────────────────────────
# These were committed before the pre-public review; keep them locally
# but never let them reach a shared remote.

# Backup variants of scan-output dirs (companion to osint_reports/, reports/)
osint_reports_backup/
reports_backup/
screenshots_backup/

# Audit log data — keep audit_writer.py tracked
scan_audit/*.jsonl

# TLS material — regenerate per-install via generate-credentials.sh
certs/server.key
certs/server.crt

# WireGuard server install state (keys, peer confs, coredns)
wireguard/server/

# Operator notes / decision log — accumulates sensitive context
Docs/Memories.md
Docs/CHANGES_MADE.md
