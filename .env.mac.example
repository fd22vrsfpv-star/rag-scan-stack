# Mac M1/M2/M3/M4/M5 Environment Configuration
# Copy to .env and adjust as needed

# Database
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=scans
DB_DSN=postgresql://app:app@rag-postgres:5432/scans

# API Keys
API_KEY=changeme
ZAP_API_KEY=changeme

# Ollama - runs NATIVELY on Mac (not in Docker)
# Install: brew install ollama && ollama serve
# On Mac, do NOT use --profile gpu (no Docker ollama container needed)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b

# For 32GB Mac, use smaller models:
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_MODEL=mistral:7b

# For 64GB+ Mac, can use larger models:
# OLLAMA_MODEL=qwen2.5:32b

# For 128GB Mac (M5 Max etc), use the best models:
# OLLAMA_MODEL=llama3.3:70b-instruct-q5_K_M
# OLLAMA_MODEL=qwen2.5:72b

# Apple Silicon GPU info (used by dashboard GPU tab)
# Set these so the dashboard shows your GPU correctly
GPU_NAME=Apple M5 Max
GPU_TOTAL_MEMORY_GB=128

# Metasploit (optional - resource heavy)
MSF_RPC_USER=msf
MSF_RPC_PASS=msf

# Web Scanner
WEB_PORTS=80,443,8080,8443,8000,8888,3000,5000

# Timezone - all containers use Eastern Time
TZ=America/New_York
