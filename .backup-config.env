# RAG Scan Stack - Backup Configuration
# This file configures the behavior of backup scripts
#
# Usage: Source this file in backup scripts
# Location: /opt/rag-scan-stack/.backup-config.env
# Permissions: chmod 600 .backup-config.env (recommended)
#
# Last Updated: 2025-11-19

# ====================
# Backup Storage
# ====================

# Base directory for all backups
# Default: /backups
BACKUP_BASE_DIR="/backups"

# Backup retention period in days
# Backups older than this will be automatically deleted
# Default: 30 days
BACKUP_RETENTION_DAYS=30

# ====================
# PostgreSQL Configuration
# ====================

# PostgreSQL container name
# Default: rag-postgres
POSTGRES_CONTAINER="rag-postgres"

# PostgreSQL superuser
# Default: app
POSTGRES_USER="app"

# ====================
# Encryption
# ====================

# Enable backup encryption using GPG
# Set to 'true' to enable encryption (requires GPG configured)
# Default: false
ENABLE_ENCRYPTION=false

# GPG encryption recipient (email or key ID)
# Used when ENABLE_ENCRYPTION=true
# Example: backup@example.com
ENCRYPTION_RECIPIENT="backup@example.com"

# ====================
# S3 / Cloud Storage
# ====================

# Enable automatic upload to S3
# Requires AWS CLI configured with credentials
# Default: false
ENABLE_S3_UPLOAD=false

# S3 bucket name for backup storage
# Example: my-company-rag-backups
# Leave empty if S3 upload is disabled
S3_BUCKET=""

# S3 region (optional)
# Example: us-east-1
S3_REGION="us-east-1"

# S3 storage class (optional)
# Options: STANDARD, STANDARD_IA, GLACIER, DEEP_ARCHIVE
# Default: STANDARD_IA (Infrequent Access - cost effective for backups)
S3_STORAGE_CLASS="STANDARD_IA"

# ====================
# Notifications
# ====================

# Enable email notifications on backup success/failure
# Requires mail command configured
# Default: false
ENABLE_EMAIL_NOTIFICATIONS=false

# Email address for backup notifications
EMAIL_NOTIFICATION_ADDRESS="ops@example.com"

# Slack webhook URL for notifications (optional)
# Example: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL=""

# ====================
# Advanced Options
# ====================

# Compress backups (recommended: true)
# Default: true
ENABLE_COMPRESSION=true

# Compression level (1-9, 9 is maximum compression)
# Default: 6 (good balance of speed and compression)
COMPRESSION_LEVEL=6

# Enable backup verification after creation
# Verifies backup integrity by testing decompression/restoration
# Default: true
ENABLE_VERIFICATION=true

# Parallel backup jobs (for large datasets)
# Number of parallel backup operations
# Default: 1 (sequential)
PARALLEL_JOBS=1

# Backup nice level (process priority)
# Higher values = lower priority (20 is lowest, -20 is highest)
# Default: 10 (slightly lower priority to not impact running services)
BACKUP_NICE_LEVEL=10

# ====================
# Logging
# ====================

# Enable verbose logging
# Default: false
VERBOSE_LOGGING=false

# Log retention days
# Backup logs older than this will be deleted
# Default: 90 days
LOG_RETENTION_DAYS=90

# ====================
# Safety Checks
# ====================

# Minimum free space required before backup (in GB)
# Backup will abort if free space is below this threshold
# Default: 10 GB
MIN_FREE_SPACE_GB=10

# Maximum backup age warning threshold (in days)
# Warn if latest backup is older than this
# Default: 2 days
MAX_BACKUP_AGE_DAYS=2

# ====================
# Example Configurations
# ====================

# Production with S3:
# BACKUP_BASE_DIR="/backups"
# BACKUP_RETENTION_DAYS=30
# ENABLE_S3_UPLOAD=true
# S3_BUCKET="mycompany-rag-prod-backups"
# ENABLE_EMAIL_NOTIFICATIONS=true
# EMAIL_NOTIFICATION_ADDRESS="ops@mycompany.com"

# Development/Testing:
# BACKUP_BASE_DIR="/tmp/backups"
# BACKUP_RETENTION_DAYS=7
# ENABLE_S3_UPLOAD=false
# ENABLE_ENCRYPTION=false

# High Security:
# BACKUP_BASE_DIR="/secure/backups"
# BACKUP_RETENTION_DAYS=90
# ENABLE_ENCRYPTION=true
# ENCRYPTION_RECIPIENT="security@mycompany.com"
# ENABLE_S3_UPLOAD=true
# S3_BUCKET="mycompany-secure-backups"
# S3_STORAGE_CLASS="GLACIER"

# ====================
# Notes
# ====================
#
# 1. Security:
#    - Set permissions: chmod 600 .backup-config.env
#    - Do not commit to version control
#    - Store sensitive values in a secrets manager if possible
#
# 2. S3 Setup:
#    - Install AWS CLI: apt-get install awscli
#    - Configure credentials: aws configure
#    - Test access: aws s3 ls s3://your-bucket/
#
# 3. Encryption Setup:
#    - Install GPG: apt-get install gnupg
#    - Import public key: gpg --import backup-public-key.asc
#    - Test encryption: echo "test" | gpg --encrypt --recipient backup@example.com
#
# 4. Email Notifications:
#    - Install mail utils: apt-get install mailutils
#    - Configure SMTP in /etc/postfix/main.cf (or similar)
#    - Test: echo "test" | mail -s "Test" ops@example.com
#
# 5. Monitoring:
#    - Monitor backup completion via cron job logs
#    - Set up alerts for backup failures
#    - Regularly test restore procedures
#
# 6. Storage Planning:
#    - Database: ~1-10GB per backup
#    - Volumes: ~10-50GB per backup
#    - Scan data: Varies (can be large)
#    - Total: Plan for 50-100GB per full backup
#    - With 30-day retention: ~1.5-3TB total
#
