# Production Environment Configuration Template
# Copy this file to .env on the target machine and update all values marked with ***CHANGE THIS***
# Or run: ./generate-credentials.sh to auto-generate all secrets

# Docker Compose Profiles — "local-db" starts local Postgres.
# Remove for remote/external DB. Add "gpu","vault","optional" as needed.
COMPOSE_PROFILES=local-db

# ==========================================
# SECURITY CREDENTIALS - CHANGE ALL OF THESE
# ==========================================

# Main API Key - used by services to authenticate with the RAG API
# ***CHANGE THIS*** - Generate a strong random key: openssl rand -hex 32
API_KEY=changeme

# PostgreSQL Database Credentials
# ***CHANGE THIS*** - Use strong passwords in production
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=scans
POSTGRES_HOST=rag-postgres
POSTGRES_PORT=5432
DB_DSN=postgresql://app:app@rag-postgres:5432/scans

# Database Role Passwords (for multi-database setup)
# ***CHANGE THESE***
# N8N_PASSWORD=changeme
# EXPLOITDB_PASSWORD=changeme
# SCANS_PASSWORD=changeme
EDB_RW_PASSWORD=changeme

# ZAP (OWASP ZAP Proxy) API Key
# ***CHANGE THIS*** - Generate: openssl rand -hex 32
ZAP_API_KEY=changeme
ZAP_ADDR=zap
ZAP_PORT=8090

# Chisel Tunnel Credentials
# ***CHANGE THIS***
CHISEL_USER=pentest
CHISEL_PASSWORD=changeme

# Metasploit RPC Credentials
# ***CHANGE THESE***
MSF_RPC_USER=msf
MSF_RPC_PASS=msf
MSF_RPC_HOST=metasploit
MSF_RPC_PORT=55553
MSF_LHOST=
MSF_LPORT=4444

# User/Group IDs for file permissions (usually keep as 1000 or match your user)
GID=1000
UID=1000

# ==========================================
# AI/RAG CONFIGURATION
# ==========================================

# Embedding model for RAG (Retrieval Augmented Generation)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Backend: "ollama" (default), "vllm", or "azure"
LLM_BACKEND=ollama

# Ollama LLM Model - change if you prefer a different model
OLLAMA_MODEL=qwen2.5:32b
# OLLAMA_URL=http://ollama:11434
OLLAMA_TIMEOUT=300

# vLLM (when LLM_BACKEND=vllm)
# VLLM_URL=http://vllm:8000
# VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# VLLM_API_KEY=changeme

# Azure AI Foundry / Azure OpenAI (when LLM_BACKEND=azure)
# AZURE_API_KEY=your-api-key
# AZURE_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_MODEL=gpt-4o
# AZURE_API_VERSION=2024-08-01-preview
# AZURE_EMBED_MODEL=text-embedding-3-small

# Autogen agent auto-execute safe tools (1=enabled, 0=disabled)
AUTO_EXECUTE_SAFE=1

# ==========================================
# NMAP SCANNER CONFIGURATION
# ==========================================

# Number of ports to batch in each scan operation
NMAP_PORT_BATCH=100

# Output directory for nmap results (inside container)
NMAP_OUT_DIR=/app/nmap_out

# Enable service/version detection (1=enabled, 0=disabled)
NMAP_SERVICE_DETECTION=1

# Version detection intensity (0-9, higher = more aggressive)
NMAP_VERSION_INTENSITY=9

# NSE scripts to run (comma-separated)
NMAP_SCRIPTS=banner,http-title,ssl-cert,ssl-enum-ciphers,ssh2-enum-algos

# Nmap scanner service URL
NMAP_SCANNER_URL=https://nmap_scanner:8012

# ==========================================
# WEB SCANNER CONFIGURATION
# ==========================================

# Wordlist for directory/file brute forcing
WORDLIST=/opt/seclists/Discovery/Web-Content/directory-list-2.3-medium.txt

# Ports to scan for web services (comma-separated)
WEB_PORTS=80,443,8080,8443,8000,8888,3000,5000

# Extended port range for deep scans
DEEP_SCAN_PORTS=1001-65535

# Scheme hint: auto, http, https
SCHEME_HINT=auto

# ==========================================
# NUCLEI VULNERABILITY SCANNER
# ==========================================

# Severity levels to scan for (comma-separated)
# Options: info, low, medium, high, critical
NUCLEI_SEVERITY=medium,high,critical

# Number of concurrent requests
NUCLEI_CONCURRENCY=50

# Rate limit (requests per minute)
NUCLEI_RATELIMIT=150

# Timeout per request (seconds)
NUCLEI_TIMEOUT=10

# Number of retries for failed requests
NUCLEI_RETRIES=1

# Auto-update templates on startup (1=enabled, 0=disabled)
NUCLEI_AUTO_UPDATE=1

# ==========================================
# PLAYWRIGHT BROWSER SCANNER
# ==========================================

# Browser engine: chromium, firefox, or webkit
BROWSER_TYPE=chromium

# Viewport dimensions for screenshots
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Custom user agent string
USER_AGENT=Mozilla/5.0 (Playwright Security Scanner)

# Enable ZAP integration for browser traffic proxying
USE_ZAP=true

# Run browser in headless mode (recommended for production)
HEADLESS=true

# Screenshot format: png or jpeg
SCREENSHOT_FORMAT=png

# ==========================================
# OSINT / EXTERNAL API KEYS
# ==========================================

# Shodan (https://account.shodan.io)
SHODAN_API_KEY=

# Censys (https://search.censys.io/account/api)
CENSYS_API_ID=
CENSYS_API_SECRET=

# ProjectDiscovery Cloud Platform
PDCP_API_KEY=

# ==========================================
# SSH TUNNEL CONFIGURATION
# ==========================================
# Start: docker compose --profile ssh-tunnel up -d ssh-tunnel

# SSH_REMOTE_HOST=your-vps-ip
# SSH_REMOTE_USER=root
# SSH_REMOTE_PORT=22
# SSH_MODE=dynamic
# SSH_SOCKS_PORT=1080
# SSH_REVERSE_BIND=0.0.0.0:9999
# SSH_REVERSE_TARGET=pentest-dashboard:80
# SSH_LOCAL_PORT=3389
# SSH_LOCAL_TARGET=127.0.0.1:3389
# SSH_KEY_PATH=./ssh-keys
# SSH_KEY_NAME=id_rsa
# SSH_EXTRA_OPTS=

# ==========================================
# AGENT/ORCHESTRATION CONFIGURATION
# ==========================================

# Enable debug logging for scan operations
SCAN_DEBUG=true

# Base API URL for internal service communication
API_BASE=https://rag-api:8000

# ==========================================
# OPEN WEBUI (optional)
# ==========================================

# OLLAMA_BASE_URL=http://ollama:11434
# OPENAI_API_BASE_URL=
# OPENAI_API_KEY=

# W&B for GRPO training (optional)
# WANDB_API_KEY=

# ==========================================
# RUNTIME
# ==========================================

# Timezone - all containers use this
TZ=America/New_York

# ==========================================
# DEPLOYMENT NOTES
# ==========================================

# 1. Generate strong random keys for API_KEY and ZAP_API_KEY:
#    openssl rand -hex 32
#
# 2. Update POSTGRES_PASSWORD with a strong password:
#    openssl rand -base64 32
#
# 3. Update DB_DSN to match your POSTGRES credentials:
#    DB_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
#
# 4. Ensure the Kong API gateway kong/kong.yml file also has the same API_KEY updated
#
# 5. For production, consider:
#    - Disabling SCAN_DEBUG
#    - Adjusting scanner concurrency/rate limits based on target environment
#    - Configuring firewall rules for exposed ports
#
# 6. Or just run: ./generate-credentials.sh to auto-generate everything

# ──────────────────────────────────────────────────────────
# HashiCorp Vault (optional — `--profile vault`)
# Production recommendation: enable Vault and remove plaintext secrets
# from this file. See app/rag-api/vault_client.py + scripts/vault-seed.sh.
# ──────────────────────────────────────────────────────────
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_MOUNT=secret
VAULT_SKIP_VERIFY=true
VAULT_PORT=8200

# ──────────────────────────────────────────────────────────
# Rate limiting + scan timeout defaults (see .env.example for full reference)
# ──────────────────────────────────────────────────────────
RATE_LIMIT=120/minute
NMAP_TIMEOUT_FALLBACK=1800
NMAP_TIMEOUT_PROXIED=3600
NMAP_TIMEOUT_SERVICE=600
NMAP_TIMEOUT_UDP=1800
NMAP_TIMEOUT_SMB=300
NMAP_TIMEOUT_RESUME=7200
INGEST_TIMEOUT=600
INGEST_TIMEOUT_SHORT=300
SCAN_TIMEOUT_CACHE_TTL=60
STALE_JOB_TIMEOUT_HOURS=24
MAX_CONCURRENT_SCANS=5
DEFAULT_MEM_LIMIT=4g
DEFAULT_CPUS=2.0
DB_POOL_MIN=2
DB_POOL_MAX=20
MAX_PIPELINE_CONCURRENT=20
PIPELINE_POLL_INTERVAL=5
