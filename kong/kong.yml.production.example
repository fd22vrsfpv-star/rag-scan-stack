# Kong API Gateway Configuration - Production Template
#
# IMPORTANT: Search and replace "REPLACE_WITH_YOUR_API_KEY" with your actual API key
# This should match the API_KEY value in your .env file
#
# Quick replacement command:
# sed -i 's/REPLACE_WITH_YOUR_API_KEY/your-actual-api-key-here/g' kong/kong.yml

_format_version: "3.0"
_transform: true

services:
  # -------- Swagger UI at / and /docs (no plugin) --------
  - name: svc-swagger-ui
    url: http://swagger-ui:8080
    routes:
      - name: r-swagger-docs
        paths: ["/docs"]      # keep /docs working too
        strip_path: false

  # -------- Raw OpenAPI specs at /specs/* --------
  - name: svc-specs
    url: http://specs:80
    routes:
      - name: r-specs
        paths: ["/specs"]
        strip_path: false
    plugins:
      - name: cors
        config:
          origins: ["*"]
          methods: ["GET","OPTIONS"]
          headers: ["*"]
          exposed_headers: ["*"]
          max_age: 3600
          credentials: false


  # -------- Backends (inject x-api-key) --------
  - name: svc-rag-api
    url: https://rag-api:8000
    routes:
      - name: r-rag-api
        paths: ["/rag-api"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-llm-query
    url: https://llm_query:8002
    routes:
      - name: r-llm-query
        paths: ["/llm"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-web-scanner
    url: https://web-scanner:8010
    routes:
      - name: r-web-scanner
        paths: ["/web"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-nuclei-runner
    url: https://nuclei-runner:8011
    routes:
      - name: r-nuclei-runner
        paths: ["/nuclei"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-nmap-scanner
    url: https://nmap_scanner:8012
    routes:
      - name: r-nmap-scanner
        paths: ["/nmap"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-scan-recommender
    url: https://scan-recommender:8013
    routes:
      - name: r-scan-recommender
        paths: ["/scan"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-playwright-scanner
    url: https://playwright-scanner:8014
    routes:
      - name: r-playwright-scanner
        paths: ["/playwright"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-autogen-agents
    url: https://autogen-agents:8015
    routes:
      - name: r-autogen-agents
        paths: ["/agents"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"

  - name: svc-zap
    url: http://zap:8090
    routes:
      - name: r-zap
        paths: ["/zap"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: REPLACE_WITH_YOUR_API_KEY"
  # ---- Root redirect to external n8n (no proxy) ----
  - name: svc-root-redirect
    url: http://127.0.0.1:9     # dummy; never used
    routes:
      - name: r-root
        paths: [ "/" ]            # only the site root
        strip_path: false
      # Optional: also redirect /n8n to the same place
      # - name: r-n8n-redirect
      #   paths: ["/n8n"]
      #   strip_path: false
    plugins:
      - name: pre-function
        config:
          access:
            - |
              -- Change this to your real n8n URL:
              local target = "http://localhost:5678/"
              -- Or e.g.: "https://n8n.example.com/"
              kong.response.set_header("Location", target)
              return kong.response.exit(302)  -- use 301 if you want permanent

  - name: svc-n8n
    url: http://n8n:5678         # dummy upstream; never used
    routes:
        - name: r-n8n
          paths: ["/n8n"]
          strip_path: true

