  # ---- Root redirect to Open WebUI ----
  - name: svc-root-redirect
    url: http://127.0.0.1:9     # dummy; never used
    routes:
      - name: r-root
        paths: [ "/" ]
        strip_path: false
    plugins:
      - name: pre-function
        config:
          access:
            - |
              local target = "http://localhost:3000/"
              kong.response.set_header("Location", target)
              return kong.response.exit(302)

  - name: svc-n8n
    url: http://n8n:5678
    routes:
        - name: r-n8n
          paths: ["/n8n"]
          strip_path: true


