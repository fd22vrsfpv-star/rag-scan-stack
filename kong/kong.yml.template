# Kong API Gateway Configuration — TEMPLATE
#
# This is the source of truth for kong/kong.yml, which is a GENERATED file
# (gitignored — it ends up holding your real API key). scripts/setup.sh copies
# this template to kong/kong.yml and substitutes the API-key placeholders below
# with the API_KEY from your .env. To regenerate by hand:
#   cp kong/kong.yml.template kong/kong.yml
#   KEY=$(grep ^API_KEY= .env | cut -d= -f2); sed -i "s/PLACEHOLDER/$KEY/g" kong/kong.yml
# (where PLACEHOLDER is the api-key value used below)
#
_format_version: "3.0"
_transform: true

services:
  # -------- Swagger UI at / and /docs (no plugin) --------
  - name: svc-swagger-ui
    url: http://swagger-ui:8080
    routes:
      - name: r-swagger-docs
        paths: ["/docs"]      # keep /docs working too
        strip_path: false

  # -------- Raw OpenAPI specs at /specs/* --------
  - name: svc-specs
    url: http://specs:80
    routes:
      - name: r-specs
        paths: ["/specs"]
        strip_path: false
    plugins:
      - name: cors
        config:
          origins: ["*"]
          methods: ["GET","OPTIONS"]
          headers: ["*"]
          exposed_headers: ["*"]
          max_age: 3600
          credentials: false


  # -------- Backends (inject x-api-key) --------
  - name: svc-rag-api
    url: https://rag-api:8000
    routes:
      - name: r-rag-api
        paths: ["/rag-api"]
        strip_path: true
    plugins:
      - name: request-transformer
        config:
          replace:
            headers:
              - "x-api-key: change-me"

  - name: svc-llm-query
    url: https://llm_query:8002
    routes:
      - name: r-llm-query
        paths: ["/llm"]
        strip_path: true
    plugins:
